# ───────────────────────── .env.example ─────────────────────────
# 복사해서 .env 로 만들고 실제 값을 채운다.  cp .env.example .env
# 실제 시크릿은 절대 커밋하지 않는다(.gitignore 가 .env 제외).

# ── PostgreSQL ──
POSTGRES_USER=eval
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=eval
# 호스트로 노출할 DB 포트(디버깅용; 운영에선 compose 에서 매핑 제거 권장)
POSTGRES_PORT=5432

# ── API (NestJS) ──
# 컨테이너 네트워크 내부에서 db 서비스명으로 접속(@db:5432). 위 POSTGRES_* 와 일치시킬 것.
DATABASE_URL=postgresql://eval:change-me-strong-password@db:5432/eval?schema=public
# 아래 두 시크릿은 반드시 새로 생성할 것. 생성 예: `openssl rand -base64 48`
JWT_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
# (선택) 토큰 만료. 미설정 시 기본 access 3600s / refresh 7d.
# JWT_ACCESS_EXPIRES_IN=3600s
# JWT_REFRESH_EXPIRES_IN=7d
# 최초 배포 시 데모 시드 주입(1회). 시드 후 false 로 되돌릴 것. 기본 false.
RUN_SEED=false
# 이메일 알림(SMTP) — 미설정 시 개발모드(콘솔/DB 폴백). 설정 시 nodemailer 로 실제 발송.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@energyx.co.kr

# ── Web (Next.js) ──
# 브라우저는 same-origin '/api/v1' 를 호출하고, Next rewrite 가 이 타깃으로 프록시한다.
# → 브라우저는 web 오리진(localhost:3000)만 알면 되고 CORS·공개 API URL 노출 불필요.
# 도커 내부 서비스명/포트 사용. rewrites 는 빌드 타임에 구워지므로 web 이미지 빌드시 주입됨.
API_PROXY_TARGET=http://api:3000

# ── 호스트 포트 매핑(컨테이너 내부는 모두 3000) ──
WEB_PORT=3000   # 호스트 3000 → web:3000
API_PORT=4000   # 호스트 4000 → api:3000
