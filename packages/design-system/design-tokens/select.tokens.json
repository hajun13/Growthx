{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "select": {
    "radius": {
      "$type": "dimension",
      "$value": "8px"
    },
    "menuRadius": {
      "$type": "dimension",
      "$value": "8px"
    },
    "size": {
      "sm": {
        "$type": "object",
        "$description": "Compact select trigger and option size.",
        "$value": {
          "triggerHeight": "36px",
          "optionHeight": "32px",
          "paddingX": "12px",
          "gap": "8px",
          "fontSize": "13px",
          "lineHeight": "18px",
          "icon": "16px"
        }
      },
      "md": {
        "$type": "object",
        "$description": "Default select trigger and option size.",
        "$value": {
          "triggerHeight": "44px",
          "optionHeight": "40px",
          "paddingX": "14px",
          "gap": "8px",
          "fontSize": "14px",
          "lineHeight": "20px",
          "icon": "18px"
        }
      },
      "lg": {
        "$type": "object",
        "$description": "Large select trigger and option size.",
        "$value": {
          "triggerHeight": "52px",
          "optionHeight": "48px",
          "paddingX": "16px",
          "gap": "10px",
          "fontSize": "16px",
          "lineHeight": "24px",
          "icon": "20px"
        }
      }
    },
    "state": {
      "default": {
        "$type": "object",
        "$description": "Idle select field.",
        "$value": {
          "background": "#FFFFFF",
          "foreground": "#111827",
          "placeholder": "#6B7280",
          "border": "#D1D5DB"
        }
      },
      "hover": {
        "$type": "object",
        "$description": "Pointer hover treatment.",
        "$value": {
          "background": "#F9FAFB",
          "border": "#9CA3AF"
        }
      },
      "open": {
        "$type": "object",
        "$description": "Expanded trigger treatment.",
        "$value": {
          "background": "#FFFFFF",
          "border": "#2563EB",
          "ring": "#2563EB"
        }
      },
      "invalid": {
        "$type": "object",
        "$description": "Validation error treatment.",
        "$value": {
          "border": "#DC2626",
          "ring": "#DC2626"
        }
      },
      "disabled": {
        "$type": "object",
        "$description": "Disabled select treatment.",
        "$value": {
          "background": "#F3F4F6",
          "foreground": "#9CA3AF",
          "border": "#E5E7EB",
          "cursor": "not-allowed"
        }
      }
    },
    "menu": {
      "$type": "object",
      "$description": "Floating menu container.",
      "$value": {
        "background": "#FFFFFF",
        "border": "#E5E7EB",
        "shadow": "0px 8px 16px 0px rgb(0 0 0 / 12%)",
        "paddingY": "4px",
        "maxHeight": "320px",
        "zIndex": "1000"
      }
    },
    "option": {
      "default": {
        "$type": "object",
        "$description": "Idle option row.",
        "$value": {
          "background": "#FFFFFF",
          "foreground": "#111827"
        }
      },
      "highlighted": {
        "$type": "object",
        "$description": "Keyboard or pointer highlighted option row.",
        "$value": {
          "background": "#F3F4F6",
          "foreground": "#111827"
        }
      },
      "selected": {
        "$type": "object",
        "$description": "Selected option row.",
        "$value": {
          "background": "#EFF6FF",
          "foreground": "#1D4ED8"
        }
      },
      "disabled": {
        "$type": "object",
        "$description": "Disabled option row.",
        "$value": {
          "foreground": "#9CA3AF"
        }
      }
    }
  }
}
