{
  "toast": {
    "width": "344px",
    "mobileWidth": "calc(100vw - 32px)",
    "duration": "2000ms",
    "fadeDuration": "120ms",
    "radius": "8px",
    "padding": {
      "single": "6px 8px 6px 16px",
      "longAction": "16px 8px 8px 16px"
    },
    "gap": "8px",
    "font": "Pretendard Regular 12px/18px",
    "actionFont": "Pretendard Medium 13px/20px",
    "elevation": "0 8px 16px rgb(0 0 0 / 12%)",
    "zIndex": 1200,
    "status": {
      "normal": "#7A37D8",
      "warn": "#D99636",
      "error": "#D93649",
      "pass": "#41B07A"
    }
  }
}
