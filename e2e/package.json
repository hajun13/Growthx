{
  "name": "@growthx/e2e",
  "version": "0.1.0",
  "private": true,
  "description": "에너지엑스 인사 평가 — Playwright E2E 테스트 하네스 (planner/generator/healer)",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:3000",
    "typecheck": "tsc --noEmit",
    "manual": "playwright test --config=playwright.manual.config.ts capture"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "20.14.10",
    "typescript": "5.5.3"
  }
}
