# ───────────────── .env.prod.example (GrowthX / KPI 시스템) ─────────────────
# 맥 프로덕션 배포용. 맥에서: cp .env.prod.example .env.prod 후 채우기.
# .env.prod 는 절대 커밋 금지.
#
# 시크릿 생성:  openssl rand -base64 48 | tr -d '/+=' | head -c 48

# ── PostgreSQL ──
POSTGRES_USER=eval
POSTGRES_PASSWORD=
POSTGRES_DB=eval

# ── JWT (자체 세션 토큰) ── 강한 값 필수.
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── SSO (Keycloak) ──
# 배포에선 issuer 는 브라우저가 보는 공개 주소(토큰 iss 와 일치),
# jwks 는 api 컨테이너가 내부 네트워크로 접근(auth 도메인 안 타고 keycloak:8080 직행).
AUTH_MODE=sso
KEYCLOAK_ISSUER=https://auth.energyx.co.kr/realms/energyx
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/energyx/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=growthx-api
KEYCLOAK_AZP=growthx-web

# 웹(빌드타임 인라인) — 브라우저가 직접 접속하는 Keycloak = 공개 주소.
NEXT_PUBLIC_AUTH_MODE=sso
NEXT_PUBLIC_KEYCLOAK_AUTHORITY=https://auth.energyx.co.kr/realms/energyx
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=growthx-web

# ── (선택) DeepSeek AI KPI 파싱 폴백 ── 없으면 결정론적 파서만.
DEEPSEEK_API_KEY=

# ── 메일(SMTP) ── M365. Direct Send 불가 → 계정 인증 경로(HVE 또는 SMTP AUTH).
# 미설정(빈 값)이면 콘솔 폴백 = 메일 미발송. 켜기 전 docs/이메일-발송-설정-맥-작업지시.md 참고.
# 경로 B(HVE): SMTP_HOST=smtp-hve.office365.com / 경로 C: smtp.office365.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@energyx.co.kr
# 메일 본문 링크의 절대 주소. 없으면 상대경로가 되어 메일에서 클릭 불가.
APP_BASE_URL=https://hr.energyx.co.kr
# 안전장치: 설정 시 이 주소들로만 실발송(쉼표 구분). SMTP 최초 검증 때 본인 주소만 넣어 리허설.
# 전체 오픈 시 비워둔다(미설정=전 임직원 발송).
MAIL_ALLOWLIST=
