# PostgreSQL 연결 문자열
DATABASE_URL="postgresql://growthx:growthx@localhost:5432/growthx?schema=public"

# JWT — 필수. 미설정 시 서버 부팅이 실패한다(코드에 기본값 없음).
#   반드시 배포마다 고유한 강한 난수로 설정할 것. 예: openssl rand -hex 32
JWT_SECRET="REQUIRED-set-a-strong-random-secret"
JWT_ACCESS_EXPIRES_IN="3600s"
JWT_REFRESH_SECRET="REQUIRED-set-a-different-strong-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# 서버
PORT=4000

# 이메일 알림(SMTP) — 미설정 시 개발모드(콘솔/DB 폴백). 설정 시 실제 발송.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@energyx.co.kr
