# PostgreSQL 연결 문자열
DATABASE_URL="postgresql://growthx:growthx@localhost:5432/growthx?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRES_IN="3600s"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# 서버
PORT=4000

# 이메일 알림(SMTP) — 미설정 시 개발모드(콘솔/DB 폴백). 설정 시 실제 발송.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@energyx.co.kr
