// 인사평가 솔루션 — Prisma 스키마 (domain-model.md, v2 도메인 대정정 반영)
// 모델명 PascalCase, DB 컬럼 snake_case(@map), 테이블 @@map.
//
// ⚠️ v2 정정(2026-06-02):
//  - 역량평가 폐기: CompetencyItem·EvaluationItem 엔티티, Dimension·JobCompetencySubtype enum 제거.
//  - 다면 폐기: EvaluationType = self + downward 만(peer·upward 제거). round(1=팀장·2=본부장).
//  - 조직 4단계: DepartmentType = group/division/team (group 최상위).
//  - KPI 분류: Kpi.category(KpiCategory)·group(KpiGroup)·measureType(MeasureType) 추가.
//  - 측정방식별 등급: RuleSet.gradingScales(amount/rate 달성률표)·Kpi.grading(count 임계값) + gradeScale 유지.
//  - EvaluationResult: dimensionGrades·multiSource 제거 → byType(self/downward1/downward2) Json.

generator client {
  provider        = "prisma-client-js"
  // Alpine(musl) 런타임에서 schema/query engine 이 OpenSSL 3.0 바이너리를 쓰도록 명시.
  // 미지정 시 컨테이너에서 libssl 감지 실패 → db push/migrate 가 깨짐.
  // x64(amd64) + arm64(Apple Silicon 맥) 둘 다 명시 — build 스테이지의 native 가
  // openssl 1.1 로 잡히면 런타임(openssl 3.0)과 어긋나 엔진 로드 실패.
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // 바운디드 컨텍스트별 물리 schema 분리 (domain-model.md §4-1). 미래의 서비스 절단선.
  schemas  = ["org", "cycle", "kpi", "evaluation", "calibration", "result", "compensation", "notification", "audit", "competency", "midterm"]
}

// ─────────────────────────── Enums ───────────────────────────

enum Role {
  hr_admin
  division_head
  team_lead
  employee

  @@schema("org")
}

// 직책(Position) — enum 폐기, 관리형 레지스트리(PositionDef)로 전환(계약 B).
// User.position·KpiCategoryPolicy.position 은 코드 문자열(String)로 저장.
// 시스템 직급 10코드: ceo/vice_president/executive/director/principal/
//   division_head/team_lead/chief/senior/pro. 커스텀 직급은 PositionDef 로 추가.

// 가시 범위 — M3 Item2: visibilityScope 기준 행수준 권한.
// self=본인 / team=본인 팀 / division=본인 본부 하위(형제 본부 제외) / group=본인 그룹 하위 / company=전체
enum VisibilityScope {
  self
  team
  division
  group
  company

  @@schema("org")
}

enum JobLevel {
  division_head
  team_lead
  senior_plus // 5년차 이상
  senior_minus // 5년차 미만

  @@schema("org")
}

// YoY: 4대보험 소속(법인). 조직도는 통합, 법인 속성으로만 구분.
enum LegalEntity {
  energyx // 에너지엑스㈜
  mirae_plan // 미래환경플랜

  @@schema("org")
}

// YoY: 재직 상태. 퇴사자는 비활성 User 로 보존(과거 결과 연결).
enum EmploymentStatus {
  active // 재직
  on_leave // 휴직
  resigned // 퇴사

  @@schema("org")
}

// 조직 4단계 — group(그룹) 최상위 → division(본부) → team(팀) → 개인
enum DepartmentType {
  group
  division
  team

  @@schema("org")
}

enum CycleStatus {
  draft
  active
  mid_review
  calibration
  closed

  @@schema("cycle")
}

enum KpiStatus {
  draft
  submitted
  approved
  confirmed

  @@schema("kpi")
}

// KPI 카테고리 (xlsx 핵심전략)
enum KpiCategory {
  revenue // 매출액
  construction // 공정액
  orders // 수주&업무수행성과
  collaboration // 협업성과
  development // 자기개발

  @@schema("kpi")
}

// KPI 2대 가중치 그룹
enum KpiGroup {
  performance_core // 성과 중심 지표 (70/80%)
  collaboration_growth // 협업 및 성장 지표 (20/30%)

  @@schema("kpi")
}

// 측정방식 — 측정방식별 등급 기준이 다름(business-rules §2)
enum MeasureType {
  amount // 달성금액 → 달성률
  rate // 증감률
  count // 건수 (임계값은 KPI별 grading)
  qualitative // 정성 (평가자 직접 등급)

  @@schema("kpi")
}

// 평가 유형 — 다면 없음. self + downward(round 1 팀장·2 본부장)
enum EvaluationType {
  self
  downward

  @@schema("evaluation")
}

enum EvaluationStatus {
  not_started
  in_progress
  revision_requested
  rejected
  submitted
  finalized

  @@schema("evaluation")
}

enum Grade {
  S
  A
  B
  C
  D

  @@schema("evaluation")
}

enum GroupTier {
  excellent
  standard
  poor

  @@schema("calibration")
}

enum CycleType {
  MIDTERM // 중간평가 (6월)
  FINAL // 최종평가 (12월)

  @@schema("cycle")
}

enum AppealStatus {
  submitted
  under_review
  answered
  closed

  @@schema("result")
}

// 이의제기 HR 최종 결정 유형 (3B-3). uphold/reject=변경없음,
// score_adjust=점수수정+보상재계산, grade_adjust=등급수정(override)+보상재계산,
// reevaluate=부서장(downward) 평가 재오픈.
enum AppealDecisionType {
  uphold
  score_adjust
  grade_adjust
  reevaluate
  reject

  @@schema("result")
}

enum ReviewKind {
  strength
  improvement

  @@schema("kpi")
}

// 6월 중간평가: 진척 점검 상태(본인 자가점검 → 부서장 확인).
enum MidtermReviewStatus {
  pending // 미시작
  // ── 신규 흐름(2026-07-23): 본부장 1차 코멘트 → 본인 수정 → 그룹대표 2차 검토 ──
  commented // 1차 코멘트 등록 완료(본인 수정 대기)
  revised // 본인 수정 제출 완료(2차 검토 대기)
  returned // 2차 반려(본인 재수정 대기)
  closed // 2차 승인 — 마감
  // ── 레거시(자가점검 흐름, 2025 데이터 보존용. 신규 생성 없음) ──
  self_done
  confirmed
  revision_requested
  rejected

  @@schema("midterm")
}

// 6월 중간평가: 피드백 보완 조치(ActionItem) 상태 머신.
// planned → in_progress → done. (+ canceled 는 어느 진행 상태에서나 가능)
// 최종등급 미반영(참고용). 상태전이는 common/state/transitions.ts(assertTransition) 강제.
enum ActionItemStatus {
  planned
  in_progress
  done
  canceled

  @@schema("midterm")
}

// ActionItem 출처 체크포인트(어느 단계 피드백에서 나온 조치인지).
enum ActionItemSource {
  midterm_review

  @@schema("midterm")
}

// ④ 중간 KPI 목표 재조정 요청(re-baseline) 상태 머신.
// 본인(피평가자)이 제안 → 부서장 검토. submitted → approved(반영·종단) | rejected.
// rejected → submitted(본인 수정·재제출). 상태전이는 transitions.ts(REBASELINE_REQUEST_TRANSITIONS) 강제.
enum RebaselineRequestStatus {
  submitted // 본인이 제출(검토 대기)
  approved // 부서장 승인 → KPI 실제 반영(종단)
  rejected // 부서장 반려 → 본인 수정·재제출 가능

  @@schema("midterm")
}

// ─────────────────────────── Entities ───────────────────────────

// 1. User
model User {
  id                     String           @id @default(uuid())
  email                  String           @unique
  name                   String
  passwordHash           String           @map("password_hash")
  role                   Role
  position               String // 직급 코드(PositionDef.code). enum 폐기 후 관리형 레지스트리.
  jobLevel               JobLevel?        @map("job_level")
  departmentId           String?          @map("department_id")
  managerId              String?          @map("manager_id")
  // M3 Item1: 초기 비밀번호(1234) 강제 변경 플래그. 임포트/신규 생성 시 true.
  // ⚠ SSO 전환(Phase 2-A) 3단계에서 삭제 예정. 값은 이미 전부 false 로 내렸다.
  mustChangePassword     Boolean          @default(false) @map("must_change_password")
  // Keycloak sub. 최초 SSO 로그인 시 바인딩된다(TOFU).
  // 주의: 이름과 달리 Azure AD subject 가 아니라 Keycloak 내부 user id 다.
  // EX-DB-API 의 employee.azure_ad_subject 와 같은 값 — Phase 2-B 의 조인 키.
  azureAdSubject         String?          @unique @map("azure_ad_subject")
  // break-glass 전용. true 인 계정만 비밀번호 로그인이 허용된다(AUTH_MODE=sso 일 때).
  allowPasswordLogin     Boolean          @default(false) @map("allow_password_login")
  // M3 Item2: 가시 범위(행수준 RBAC). 임포트 시 직급 자동기본, 관리자 수동 오버라이드.
  visibilityScope        VisibilityScope  @default(self) @map("visibility_scope")
  // M3 조직도: 비활성(soft delete).
  isActive               Boolean          @default(true) @map("is_active")
  // 평가 제외: 재직 중이나 이번 평가 대상이 아님(하반기 입사·파견 등). HR 토글.
  // true면 부서장 평가 자동배정·그룹 등급 풀 집계에서 제외된다.
  evaluationExempt       Boolean          @default(false) @map("evaluation_exempt")
  evaluationExemptReason String?          @map("evaluation_exempt_reason")
  // YoY: 법인(4대보험 소속). 기본 energyx. 조직도는 통합, 뱃지/필터로만 구분.
  legalEntity            LegalEntity      @default(energyx) @map("legal_entity")
  // YoY: 재직 상태. 퇴사자(임포트)는 resigned + isActive=false 로 보존.
  employmentStatus       EmploymentStatus @default(active) @map("employment_status")
  resignedAt             DateTime?        @map("resigned_at")
  hireDate               DateTime?        @map("hire_date") // 입사일. 평가 제외 기준(EvaluationCycle.hireCutoffDate) 적용 시 참조.
  // 생년월일. 나이(만 나이)는 응답에서 파생(저장 안 함). 조직도 기초DATA 적재·표시용.
  birthDate              DateTime?        @map("birth_date")
  // 프로필 사진 URL. null이면 프론트 Avatar가 이니셜 폴백 렌더.
  avatarUrl              String?          @map("avatar_url")
  // M3 Item 8: 연봉 시뮬레이션 — 현재 연봉(hr_admin만 입력). null=미입력.
  currentSalary          Float?           @map("current_salary")
  previousSalary         Float?           @map("previous_salary") // 전년도 연봉(보상 현황). null=미입력.
  // 보상 현황 표(2026 연봉갱신 Index 시트) 경력/연봉 컬럼. 모두 nullable(적재 미완료 허용).
  priorCareerMonths         Int?    @map("prior_career_months") // 전경력(월). 입사 전 경력.
  careerBaseMonths          Int?    @map("career_base_months") // 25.02 기준 경력(월).
  careerPosition            String? @map("career_position") // 경력직급(엑셀 라벨).
  serviceYears              Int?    @map("service_years") // 연차.
  considerationExclusion    String? @map("consideration_exclusion") // 고려대상 열외 라벨(비대상/육아휴직/임원/감리원/대표 등).
  currentSalaryExclTransfer Int?    @map("current_salary_excl_transfer") // 25년도 연봉(이전제외A). null이면 currentSalary 폴백.
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  department  Department?  @relation(fields: [departmentId], references: [id])
  manager     User?        @relation("UserManager", fields: [managerId], references: [id])
  reports     User[]       @relation("UserManager")
  // 이 사용자가 명시적 장으로 지정된 부서들(그룹·본부·팀).
  headOfDepts Department[] @relation("DeptHead")
  // 이 사용자가 부(副)그룹장(부대표)으로 지정된 그룹들.
  deputyHeadOfDepts Department[] @relation("DeptDeputyHead")

  kpis                          Kpi[]
  evaluationsAsEvaluator        Evaluation[]         @relation("Evaluator")
  evaluationsAsEvaluatee        Evaluation[]         @relation("Evaluatee")
  comments                      Comment[]
  reviews                       Review[]
  results                       EvaluationResult[]
  appeals                       Appeal[]             @relation("AppealUser")
  decidedAppeals                Appeal[]             @relation("AppealDecider")
  respondedAppeals              Appeal[]             @relation("AppealResponder")
  compensations                 Compensation[]
  compensationAdjustments       CompensationAdjustment[]
  notifications                 Notification[]
  auditLogs                     AuditLog[]
  // M3
  monthlyPerformances           MonthlyPerformance[] @relation("MonthlyPerformanceEnteredBy")
  competencyQuestions           CompetencyQuestion[] @relation("CompetencyQuestionCreatedBy")
  competencyResponses           CompetencyResponse[] @relation("CompetencyResponseUser")
  competencyResponsesAsEvaluator CompetencyResponse[] @relation("CompetencyResponseEvaluator")
  competencyOpinions            CompetencyOpinion[]  @relation("CompetencyOpinionUser")
  competencyOpinionsAsEvaluator CompetencyOpinion[]  @relation("CompetencyOpinionEvaluator")
  // Cycle Ops §4
  kpiSnapshots                  KpiSnapshot[]
  // 6월 중간평가
  midtermReviewsAsEvaluatee     MidtermReview[]      @relation("MidtermReviewEvaluatee")
  midtermReviewsAsReviewer      MidtermReview[]      @relation("MidtermReviewReviewer")
  midtermFirstReviews           MidtermReview[]      @relation("MidtermFirstReviewer")
  midtermFinalReviews           MidtermReview[]      @relation("MidtermFinalReviewer")
  midtermTrails                 MidtermTrail[]
  actionItemsAsEvaluatee        ActionItem[]         @relation("ActionItemEvaluatee")
  actionItemsAsAssignee         ActionItem[]         @relation("ActionItemAssignee")
  actionItemsCreated            ActionItem[]         @relation("ActionItemCreatedBy")
  rebaselineRequestsAsEvaluatee RebaselineRequest[]  @relation("RebaselineRequestEvaluatee")
  rebaselineRequestsAsReviewer  RebaselineRequest[]  @relation("RebaselineRequestReviewer")
  // 평가 검토 이력(수정요청·반려·승인)에서 이 사용자가 액션 행위자인 항목.
  evalReviewActions             EvaluationReviewHistory[] @relation("EvalReviewActor")
  // SSO: Azure AD 이메일이 email 과 다른 경우의 보조 매칭 키.
  emailAliases                  UserEmailAlias[]

  @@index([departmentId])
  @@index([managerId])
  @@map("users")
  @@schema("org")
}

/// Azure AD 이메일 ≠ org.users.email 인 사용자의 보조 매칭 키(SSO 최초 로그인 바인딩용).
/// 예: 박성현 대표이사 — Keycloak spark@energyx.co.kr → users spark@energyx.ai
/// 시드 117명 중 도메인이 다른 유일한 계정이며, 하필 hr_admin 이다.
///
/// email 을 PK 로 둔다: 같은 Keycloak 이메일이 두 사용자를 가리키면 안 된다.
model UserEmailAlias {
  email     String   @id
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_email_aliases")
  @@schema("org")
}

// 2. Department (트리) — group → division → team
model Department {
  id            String         @id @default(uuid())
  name          String
  type          DepartmentType
  parentId      String?        @map("parent_id")
  // 명시적 부서장(그룹장·본부장·팀장) 지정. null=자동 추론(role 기반). 사용자 삭제 시 SetNull.
  headUserId    String?        @map("head_user_id")
  // 그룹 부(副)장(부대표 등) 지정 — group 타입 전용. 지정 시 다단계 하향평가에서
  // 팀장(1차 본부장→2차 부그룹장)·본부장(1차 부그룹장)의 중간 평가 단계로 들어간다.
  // 일반 직원 평가(팀장→본부장→그룹장)에는 관여하지 않는다. null=중간 단계 없음.
  deputyHeadUserId String?     @map("deputy_head_user_id")
  isEngineering Boolean        @default(false) @map("is_engineering")
  createdAt     DateTime       @default(now()) @map("created_at")

  parent     Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children   Department[] @relation("DepartmentTree")
  users      User[]
  head       User?        @relation("DeptHead", fields: [headUserId], references: [id], onDelete: SetNull)
  deputyHead User?        @relation("DeptDeputyHead", fields: [deputyHeadUserId], references: [id], onDelete: SetNull)

  groupPerformances   GroupPerformance[]
  gradePools          GradePool[]
  // M3
  monthlyPerformances MonthlyPerformance[]

  @@index([parentId])
  @@map("departments")
  @@schema("org")
}

// 3. EvaluationCycle
model EvaluationCycle {
  id        String      @id @default(uuid())
  name      String
  year      Int
  startDate DateTime    @map("start_date")
  endDate   DateTime    @map("end_date")
  status    CycleStatus @default(draft)
  cycleType CycleType   @default(FINAL) @map("cycle_type")
  ruleSetId String?     @unique @map("rule_set_id")
  // 입사일 기준 평가 제외: 이 날짜 이후 입사자는 평가 대상에서 제외. null = 제한 없음.
  hireCutoffDate DateTime? @map("hire_cutoff_date")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  ruleSet             RuleSet?             @relation(fields: [ruleSetId], references: [id])
  schedules           CycleSchedule[]
  kpiTemplates        KpiTemplate[]
  kpis                Kpi[]
  evaluations         Evaluation[]
  groupPerformances   GroupPerformance[]
  gradePools          GradePool[]
  results             EvaluationResult[]
  compensations       Compensation[]
  compensationAdjustments CompensationAdjustment[]
  // M3
  monthlyPerformances MonthlyPerformance[]
  competencyQuestions CompetencyQuestion[]
  competencyResponses CompetencyResponse[]
  competencyOpinions  CompetencyOpinion[]
  // Cycle Ops §4
  kpiSnapshots        KpiSnapshot[]
  // 알림 자동화: 단계별 D-N 리마인더 발송 멱등 추적.
  reminderDispatches  ReminderDispatch[]
  // 6월 중간평가
  midtermReviews      MidtermReview[]
  actionItems         ActionItem[]
  rebaselineRequests  RebaselineRequest[]

  @@map("evaluation_cycles")
  @@schema("cycle")
}

// 4. RuleSet (설정 가능 규칙)
// gradeScale: 점수→등급. gradingScales: 측정방식별(amount/rate) 달성률→등급.
// poolRatios: 그룹 tier별 분포 상한. raiseRates: 등급별 인상률. weightPolicy: 합100·정성≤30.
// 평가 제외(입사일 기준)는 EvaluationCycle.hireCutoffDate 에서 관리한다.
// weightPolicy JSON 스키마:
// {
//   performanceWeight: 80,   // 성과평가 가중치(%)
//   competencyWeight: 20,    // 역량평가 가중치(%) — 연봉 미반영
//   evaluatorWeights: { teamLeader: 0.5, divisionHead: 0.3, ceo: 0.2 },
//   groupTierBonus: { excellent: 0.02, standard: 0.0, poor: -0.01 },
//   revenueGradeScale: [
//     { minAmount: 1000000000, grade: "S" },
//     { minAmount: 800000000,  grade: "A" },
//     { minAmount: 600000000,  grade: "B" },
//     { minAmount: 400000000,  grade: "C" },
//     { minAmount: 0,          grade: "D" }
//   ]
// }
model RuleSet {
  id            String   @id @default(uuid())
  cycleId       String?  @map("cycle_id")
  gradeScale    Json     @map("grade_scale")
  gradingScales Json     @map("grading_scales")
  poolRatios    Json     @map("pool_ratios")
  raiseRates    Json     @map("raise_rates")
  weightPolicy  Json     @map("weight_policy")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  cycle EvaluationCycle?

  @@map("rule_sets")
  @@schema("cycle")
}

// 5. KpiTemplate (직급별 KPI 양식)
model KpiTemplate {
  id        String   @id @default(uuid())
  cycleId   String   @map("cycle_id")
  jobLevel  JobLevel @map("job_level")
  createdAt DateTime @default(now()) @map("created_at")

  cycle EvaluationCycle   @relation(fields: [cycleId], references: [id])
  items KpiTemplateItem[]

  @@index([cycleId])
  @@map("kpi_templates")
  @@schema("cycle")
}

// 6. KpiTemplateItem (양식 항목) — category/group/measureType 기반
model KpiTemplateItem {
  id                 String      @id @default(uuid())
  templateId         String      @map("template_id")
  category           KpiCategory
  group              KpiGroup
  sampleStrategy     String?     @map("sample_strategy")
  defaultMeasureType MeasureType @map("default_measure_type")
  defaultWeight      Int         @map("default_weight")
  isQualitative      Boolean     @default(false) @map("is_qualitative")

  template KpiTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("kpi_template_items")
  @@schema("cycle")
}

// 7. Kpi (개인 KPI/과제) — category/group/measureType 추가
model Kpi {
  id                String      @id @default(uuid())
  userId            String      @map("user_id")
  cycleId           String      @map("cycle_id")
  category          KpiCategory
  group             KpiGroup
  coreStrategy      String?     @map("core_strategy")
  csf               String?
  title             String
  measureMethod     String?     @map("measure_method")
  measureType       MeasureType @map("measure_type")
  targetValue       Float?      @map("target_value")
  targetText        String?     @map("target_text") // 서술형 2026 목표(엑셀 F열). targetValue(숫자)와 병존.
  weight            Int
  isQualitative     Boolean     @default(false) @map("is_qualitative")
  // 갭#2: measureType=amount 일 때만 의미. true 면 목표 대비 달성률 대신 실제 매출 절대금액 → RuleSet.revenueGradeScale 로 등급 산출.
  useAbsoluteAmount Boolean     @default(false) @map("use_absolute_amount")
  grading           Json? // count 측정방식의 건수→등급 임계값(KPI별). amount/rate는 RuleSet.gradingScales 사용.
  gradingCriteria   Json?       @map("grading_criteria") // 정성 등급기준 {S,A,B,C,D} 텍스트(엑셀 L~P열). grading(건수 임계값)과 별개.
  parentKpiId       String?     @map("parent_kpi_id")
  status            KpiStatus   @default(draft)
  rejectReason      String?     @map("reject_reason")
  // 순차 결재선(2026-07-07): 완료된 결재 단계 수. 체인=resolveDownwardEvaluators(1차 팀장→2차 본부장→최종 그룹대표, 압축).
  // submitted+0=1차 대기, approved+n=중간 승인(다음 단계 대기), confirmed=전 단계 완료.
  approvalStage     Int         @default(0) @map("approval_stage")
  // 결재 이력 [{stage, approverId, approverName, at}] — 화면 표시용(감사는 AuditLog 별도).
  approvalTrail     Json?       @map("approval_trail")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user      User            @relation(fields: [userId], references: [id])
  cycle     EvaluationCycle @relation(fields: [cycleId], references: [id])
  parentKpi Kpi?            @relation("KpiCascade", fields: [parentKpiId], references: [id])
  childKpis Kpi[]           @relation("KpiCascade")

  achievements    Achievement[]
  reviews         Review[]
  kpiScores       KpiScore[]
  evidence        EvaluationEvidence[]
  actionItems     ActionItem[]
  midtermCheckIns MidtermKpiCheckIn[]

  @@index([userId])
  @@index([cycleId])
  @@index([parentKpiId])
  @@map("kpis")
  @@schema("kpi")
}

// 8. Achievement (분기 실적)
model Achievement {
  id              String   @id @default(uuid())
  kpiId           String   @map("kpi_id")
  quarter         Int
  actualValue     Float    @map("actual_value")
  achievementRate Float    @map("achievement_rate")
  evidenceUrl     String?  @map("evidence_url")
  createdAt       DateTime @default(now()) @map("created_at")

  kpi Kpi @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([kpiId])
  @@map("achievements")
  @@schema("kpi")
}

// 9. GroupPerformance (그룹 실적) — groupId 단위
model GroupPerformance {
  id              String    @id @default(uuid())
  groupId         String    @map("group_id")
  cycleId         String    @map("cycle_id")
  revenue         Float?
  orders          Float?
  profit          Float?
  achievementRate Float     @map("achievement_rate")
  tier            GroupTier
  createdAt       DateTime  @default(now()) @map("created_at")

  group Department      @relation(fields: [groupId], references: [id])
  cycle EvaluationCycle @relation(fields: [cycleId], references: [id])

  @@unique([groupId, cycleId])
  @@map("group_performances")
  @@schema("calibration")
}

// 10. GradePool (그룹 등급 풀) — groupId 단위
model GradePool {
  id      String    @id @default(uuid())
  cycleId String    @map("cycle_id")
  groupId String    @map("group_id")
  tier    GroupTier
  sRatio  Float     @map("s_ratio")
  aRatio  Float     @map("a_ratio")
  bRatio  Float     @map("b_ratio")
  cRatio  Float     @map("c_ratio")
  dRatio  Float     @map("d_ratio")

  cycle EvaluationCycle @relation(fields: [cycleId], references: [id])
  group Department      @relation(fields: [groupId], references: [id])

  @@unique([cycleId, groupId])
  @@map("grade_pools")
  @@schema("calibration")
}

// 11. Evaluation (개별 평가) — type(self/downward) + round(1 팀장·2 본부장)
model Evaluation {
  id            String           @id @default(uuid())
  cycleId       String           @map("cycle_id")
  evaluatorId   String           @map("evaluator_id")
  evaluateeId   String           @map("evaluatee_id")
  type          EvaluationType
  round         Int?
  status        EvaluationStatus @default(not_started)
  totalScore    Float?           @map("total_score")
  finalGrade    Grade?           @map("final_grade")
  // B-3a: 평가자가 자동 산정값 위에 종합등급을 수동 오버라이드(사유 필수).
  overallGrade  Grade?           @map("overall_grade")
  overallReason String?          @map("overall_reason")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  cycle     EvaluationCycle @relation(fields: [cycleId], references: [id])
  evaluator User            @relation("Evaluator", fields: [evaluatorId], references: [id])
  evaluatee User            @relation("Evaluatee", fields: [evaluateeId], references: [id])

  kpiScores KpiScore[]
  comments  Comment[]
  evidence  EvaluationEvidence[]
  reviewHistory EvaluationReviewHistory[]

  @@unique([cycleId, evaluatorId, evaluateeId, type, round])
  @@index([cycleId])
  @@index([evaluateeId])
  @@map("evaluations")
  @@schema("evaluation")
}

// 11b. EvaluationEvidence (본인평가 문항별 증빙 첨부)
// (evaluationId, kpiId) 단위로 첨부 — KpiScore 는 저장 시마다 재생성되므로 kpiId 에 직접 묶는다.
// 파일 바이트는 DB(Bytes)에 보관(자체호스팅 Docker, postgres 볼륨으로 영속). 파일당 상한은 컨트롤러에서 강제.
model EvaluationEvidence {
  id           String   @id @default(uuid())
  evaluationId String   @map("evaluation_id")
  kpiId        String   @map("kpi_id")
  filename     String
  mimeType     String   @map("mime_type")
  size         Int
  data         Bytes
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  kpi        Kpi        @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@index([evaluationId, kpiId])
  @@map("evaluation_evidence")
  @@schema("evaluation")
}

// 11c. EvaluationReviewHistory (평가 검토 이력)
// 부서장/HR 의 수정요청·반려·승인 액션을 평가별로 명시 적재한다.
// reason/comment 사유는 피평가자에게 노출되는 피드백 근거.
enum EvaluationReviewKind {
  revision_requested
  rejected
  approved

  @@schema("evaluation")
}

model EvaluationReviewHistory {
  id           String               @id @default(uuid())
  evaluationId String               @map("evaluation_id")
  kind         EvaluationReviewKind
  reason       String?
  actorId      String               @map("actor_id")
  createdAt    DateTime             @default(now()) @map("created_at")

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  actor      User       @relation("EvalReviewActor", fields: [actorId], references: [id])

  @@index([evaluationId])
  @@map("evaluation_review_history")
  @@schema("evaluation")
}

// 12. KpiScore (과제별 성과 점수) — 평가는 KpiScore 로만 구성(역량 항목 없음)
model KpiScore {
  id              String  @id @default(uuid())
  evaluationId    String  @map("evaluation_id")
  kpiId           String  @map("kpi_id")
  achievementRate Float?  @map("achievement_rate")
  // 갭#2: 절대금액 모드(Kpi.useAbsoluteAmount=true) KPI 의 실제 매출 절대금액(원). 등급 산정 입력.
  actualAmount    Float?  @map("actual_amount")
  grade           Grade?
  score           Float
  weight          Int
  selfNote        String? @map("self_note")
  // 부서장(검토자)이 문항별로 남기는 평가 코멘트. self 평가의 selfNote 와 별개(각 평가의 KpiScore 에 귀속).
  reviewerNote    String? @map("reviewer_note")

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  kpi        Kpi        @relation(fields: [kpiId], references: [id])

  @@index([evaluationId])
  @@map("kpi_scores")
  @@schema("evaluation")
}

// 13. Review (분기 리뷰 / KPI 검토 의견)
model Review {
  id        String     @id @default(uuid())
  kpiId     String     @map("kpi_id")
  quarter   Int
  kind      ReviewKind
  content   String
  authorId  String     @map("author_id")
  createdAt DateTime   @default(now()) @map("created_at")

  kpi    Kpi  @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([kpiId])
  @@map("reviews")
  @@schema("kpi")
}

// 14. Comment (평가 코멘트 — 필수)
model Comment {
  id           String   @id @default(uuid())
  evaluationId String   @map("evaluation_id")
  authorId     String   @map("author_id")
  quarter      Int
  content      String
  createdAt    DateTime @default(now()) @map("created_at")

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id])

  @@index([evaluationId])
  @@map("comments")
  @@schema("evaluation")
}

// 15. EvaluationResult (최종 결과) — byType(self/downward1/downward2) 집계
model EvaluationResult {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  cycleId            String   @map("cycle_id")
  finalGrade         Grade?   @map("final_grade")
  finalScore         Float?   @map("final_score")
  percentile         Float?
  byType             Json?    @map("by_type") // 라이브: {self,downward1,downward2} · 임포트(YoY): {round1,round2,final,source} 실적·역량 원형
  byGroup            Json?    @map("by_group") // B-3d: { performance_core, collaboration_growth } 점수·등급
  companyAvg         Float?   @map("company_avg")
  // YoY: 당시 조직 스냅샷(조직개편 무관 비교). 임포트 시 채움.
  groupSnapshot      String?  @map("group_snapshot")
  divisionSnapshot   String?  @map("division_snapshot")
  teamSnapshot       String?  @map("team_snapshot")
  // 결함 #7: 동명 부서 매칭 어긋남 방지 — 당시 조직의 부서 id 스냅샷(이름 스냅샷과 병행).
  groupIdSnapshot    String?  @map("group_id_snapshot")
  divisionIdSnapshot String?  @map("division_id_snapshot")
  teamIdSnapshot     String?  @map("team_id_snapshot")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user  User            @relation(fields: [userId], references: [id])
  cycle EvaluationCycle @relation(fields: [cycleId], references: [id])

  appeals Appeal[]

  @@unique([userId, cycleId])
  @@index([teamIdSnapshot])
  @@index([divisionIdSnapshot])
  @@index([groupIdSnapshot])
  @@map("evaluation_results")
  @@schema("result")
}

// 16. Appeal (이의제기) — 신청(7일)·1차 답변(팀장)·HR 최종 결정
model Appeal {
  id            String       @id @default(uuid())
  resultId      String       @map("result_id")
  userId        String       @map("user_id")
  reason        String
  status        AppealStatus @default(submitted)
  response      String? // 팀장 1차 답변
  respondedById String?      @map("responded_by_id")
  decision      String? // HR 최종 결정 사유(자유 텍스트) — 유지
  decidedById   String?      @map("decided_by_id")
  // 3B-3: 구조화된 결정 유형 + 자동수정 값.
  decisionType  AppealDecisionType? @map("decision_type")
  newScore      Float?              @map("new_score") // score_adjust 시 새 finalScore
  newGrade      Grade?              @map("new_grade") // grade_adjust 시 새 finalGrade(override)
  // 진행단계 타임스탬프(접수=createdAt·검토시작·부서장답변·HR결정).
  reviewStartedAt DateTime? @map("review_started_at")
  respondedAt     DateTime? @map("responded_at")
  decidedAt       DateTime? @map("decided_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  result      EvaluationResult @relation(fields: [resultId], references: [id])
  user        User             @relation("AppealUser", fields: [userId], references: [id])
  respondedBy User?            @relation("AppealResponder", fields: [respondedById], references: [id])
  decidedBy   User?            @relation("AppealDecider", fields: [decidedById], references: [id])

  attachments AppealAttachment[]

  @@index([resultId])
  @@map("appeals")
  @@schema("result")
}

// 16b. AppealAttachment (이의제기 증빙 첨부, EvaluationEvidence 패턴 재사용)
// 파일 바이트는 DB(Bytes)에 보관(자체호스팅 Docker, postgres 볼륨 영속).
// 파일당 상한·MIME 화이트리스트는 컨트롤러/서비스에서 강제.
model AppealAttachment {
  id           String   @id @default(uuid())
  appealId     String   @map("appeal_id")
  filename     String
  mimeType     String   @map("mime_type")
  size         Int
  data         Bytes
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  appeal Appeal @relation(fields: [appealId], references: [id], onDelete: Cascade)

  @@index([appealId])
  @@map("appeal_attachments")
  @@schema("result")
}

// 17. Compensation (보상 연동)
model Compensation {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  cycleId        String   @map("cycle_id")
  finalGrade     Grade    @map("final_grade")
  raiseRate      Float    @map("raise_rate")
  baseSalary     Int?     @map("base_salary") // 이 사이클의 금년도 연봉(산정 기준) 스냅샷. 표시·감사용.
  // 제안연봉 스냅샷 = baseSalary * (1 + raiseRate/100) + 조정분. 다음 사이클의 금년도 연봉과 같은 값이나,
  // 파생은 previous-salary.deriver(연봉 체인)가 조정분에서 실시간 재계산한다 — 이 컬럼은 읽지 않는다.
  nextYearSalary Int?     @map("next_year_salary")
  simulated      Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  user  User            @relation(fields: [userId], references: [id])
  cycle EvaluationCycle @relation(fields: [cycleId], references: [id])

  @@unique([userId, cycleId, simulated])
  @@map("compensations")
  @@schema("compensation")
}

// 17-1. CompensationAdjustment (보상 수기 조정 — 2026 연봉갱신 엑셀 T~AC 양식)
// 관리자가 (user, cycle)별로 조정분·승격·인센티브·비고를 수기 입력·저장.
// 자동 산정(Compensation/projectedSalary)과 별개로 시뮬레이션 응답에 병합되어 최종 제안연봉·인상률을 산출.
model CompensationAdjustment {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  cycleId               String   @map("cycle_id")
  adjustmentAmount      Int?     @map("adjustment_amount") // 조정분(원, 음수 허용) — 엑셀 X열
  promotionPositionCode String?  @map("promotion_position_code") // 승격 직급 PositionDef.code — 엑셀 AA열(FK 강제 안 함)
  incentiveAmount       Int?     @map("incentive_amount") // 인센티브(원) — 엑셀 AB열
  note                  String? // 비고 — 엑셀 AC열
  updatedAt             DateTime @updatedAt @map("updated_at")
  createdAt             DateTime @default(now()) @map("created_at")

  user  User            @relation(fields: [userId], references: [id])
  cycle EvaluationCycle @relation(fields: [cycleId], references: [id])

  @@unique([userId, cycleId])
  @@map("compensation_adjustments")
  @@schema("compensation")
}

// 18. Notification (알림) — D-7/D-1/D-3
model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  payload   Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
  @@schema("notification")
}

// B-2. CycleSchedule (주기 단계별 일정·대상자·알림 트리거)
// phase: 평가준비/본인평가/1차/2차/결과. dueDate: 마감일.
// notifyOffsets: 알림 리드타임(예: [7,3,1] = D-7/D-3/D-1). targetUserIds/targetDeptIds: 대상자.
model CycleSchedule {
  id            String    @id @default(uuid())
  cycleId       String    @map("cycle_id")
  phase         String
  // M3 Item 5: 단계 시작일. null이면 dueDate만으로 활성 윈도우 판정.
  startDate     DateTime? @map("start_date")
  dueDate       DateTime  @map("due_date")
  notifyOffsets Json      @default("[7, 3, 1]") @map("notify_offsets")
  notifyEnabled Boolean   @default(true) @map("notify_enabled")
  targetUserIds Json      @default("[]") @map("target_user_ids")
  targetDeptIds Json      @default("[]") @map("target_dept_ids")
  // M3 Item 5: 평가 기간 잠금. true=해당 phase의 KPI 작성/수정 차단(423).
  isLocked      Boolean   @default(false) @map("is_locked")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  cycle EvaluationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, phase])
  @@index([cycleId])
  @@map("cycle_schedules")
  @@schema("cycle")
}

// 알림 자동화: 단계별 D-N 리마인더가 (cycle·phase·offset) 단위로 한 번만 발송되도록
// 보장하는 멱등 마커. 크론이 매일 돌더라도, 이미 발송한 (cycle,phase,offset)은 건너뛴다.
model ReminderDispatch {
  id           String   @id @default(uuid())
  cycleId      String   @map("cycle_id")
  phase        String
  offset       Int // D-offset (예: 7/3/1)
  recipients   Int      @default(0) // 발송 인원 수(감사·디버깅용)
  dispatchedAt DateTime @default(now()) @map("dispatched_at")

  cycle EvaluationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, phase, offset])
  @@index([cycleId])
  @@map("reminder_dispatches")
  @@schema("notification")
}

// 18b. KpiSnapshot (Cycle Ops §4) — 1차 확정 시점 KPI 캡처. diff 비교 기준.
model KpiSnapshot {
  id        String   @id @default(uuid())
  cycleId   String   @map("cycle_id")
  userId    String   @map("user_id")
  label     String // 예: "1차 확정"
  data      Json // 해당 시점 KPI 배열 직렬화(SnapshotKpi[])
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  cycle EvaluationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  user  User            @relation(fields: [userId], references: [id])

  @@index([cycleId, userId])
  @@map("kpi_snapshots")
  @@schema("kpi")
}

// 19. AuditLog (감사 로그)
model AuditLog {
  id       String   @id @default(uuid())
  entity   String
  entityId String   @map("entity_id")
  action   String
  before   Json?
  after    Json?
  userId   String?  @map("user_id")
  ip       String?
  at       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([action])
  @@index([at])
  @@map("audit_logs")
  @@schema("audit")
}

// ─────────────────────────── M3 (Items 4·6) ───────────────────────────

// M3-1. MonthlyPerformance (월별 실적 입력) — Item 4
// 그룹/본부의 월별 목표·실적을 카테고리별로 누적 입력. GroupPerformance(연 집계)와 구분.
// 누적 달성률 = Σ(actualAmount) / 연간 targetAmount → Grade(amount 달성률표) 매핑.
// 월별 실적 저장 상태 — draft(임시저장, 미확정) / final(최종저장, 확정).
// 집계(대시보드·그룹실적·중간진척)는 final 만, 편집 그리드(list·financial-grid)는 draft 포함.
enum MonthlyPerformanceStatus {
  draft
  final

  @@schema("compensation")
}

model MonthlyPerformance {
  id           String      @id @default(uuid())
  cycleId      String      @map("cycle_id")
  departmentId String      @map("department_id") // group 또는 division
  year         Int
  month        Int // 1~12 (월별 실적). month=0 = 전년도(2024) 연간 참고 sentinel — 집계 제외.
  category     KpiCategory
  targetAmount Float       @map("target_amount") // 매출 목표 (해당 월). 대시보드/summary 의 매출 소스.
  actualAmount Float       @map("actual_amount") // 매출 실적 (해당 월).
  costTarget   Float?      @map("cost_target") // 원가 목표 (경영실적 그리드). 매출총이익=매출-원가.
  costActual   Float?      @map("cost_actual") // 원가 실적.
  revenueNote  String?     @map("revenue_note") // 매출 행 비고(월별 입력 표, 자유 텍스트).
  costNote     String?     @map("cost_note") // 원가 행 비고.
  status       MonthlyPerformanceStatus @default(final) @map("status") // draft=임시저장/final=최종저장. 기존 행은 default(final) 백필 — 대시보드 수치 불변.
  enteredById  String      @map("entered_by_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  cycle      EvaluationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  department Department      @relation(fields: [departmentId], references: [id])
  enteredBy  User            @relation("MonthlyPerformanceEnteredBy", fields: [enteredById], references: [id])

  @@unique([cycleId, departmentId, year, month, category])
  @@index([cycleId])
  @@index([departmentId])
  @@map("monthly_performances")
  @@schema("compensation")
}

// M3-0. CompetencyCategory — 역량 평가 카테고리 레지스트리 (글로벌, 사이클 독립)
// 하드코딩 문자열(리더십/협업/전문성/혁신) 대체. HR이 추가/비활성/순서 관리.
model CompetencyCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  questions CompetencyQuestion[]

  @@map("competency_categories")
  @@schema("competency")
}

// M3-2. CompetencyQuestion (역량 평가 질문) — Item 6
// HR 관리자가 설정하는 역량 평가 문항. 연봉 미반영(참고 데이터).
model CompetencyQuestion {
  id          String   @id @default(uuid())
  cycleId     String   @map("cycle_id")
  order       Int      @default(0)
  text        String
  hint        String?
  categoryId  String   @map("category_id")
  options     String[] @default([]) // 문항별 커스텀 5지선다 보기. []=레거시/폴백, 값 있으면 정확히 5개. 인덱스0→점수1(등급D) … 인덱스4→점수5(등급S).
  weight      Int      @default(0) // % 가중치
  targetGroup String   @default("all") @map("target_group") // all=전 임직원 / manager=직책자 / non_manager=비직책자
  isActive    Boolean  @default(true) @map("is_active")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cycle     EvaluationCycle      @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  category  CompetencyCategory   @relation(fields: [categoryId], references: [id])
  createdBy User                 @relation("CompetencyQuestionCreatedBy", fields: [createdById], references: [id])
  responses CompetencyResponse[]

  @@index([cycleId])
  @@index([categoryId])
  @@map("competency_questions")
  @@schema("competency")
}

// M3-3. CompetencyResponse (역량 평가 응답) — Item 6
// 임직원 본인(self) + 다단계 부서장(round1~3)이 질문별 S/A/B/C/D 등급 + 코멘트로 응답.
// userId=피평가자, evaluatorId=이 행을 작성한 평가자(본인평가는 userId 와 동일).
// stage=self/round1/round2/round3 — 엑셀 역량평가서의 본인/1차/2차/최종 열에 대응.
// 질문·피평가자·주기·단계 단위 유일. 환산 점수는 저장하지 않고 조회 시 계산(참고용, 연봉 미반영).
model CompetencyResponse {
  id          String    @id @default(uuid())
  questionId  String    @map("question_id")
  userId      String    @map("user_id")
  cycleId     String    @map("cycle_id")
  stage       String    @default("self")
  evaluatorId String    @map("evaluator_id")
  grade       Grade
  comment     String?
  submittedAt DateTime? @map("submitted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  question  CompetencyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user      User               @relation("CompetencyResponseUser", fields: [userId], references: [id])
  evaluator User               @relation("CompetencyResponseEvaluator", fields: [evaluatorId], references: [id])
  cycle     EvaluationCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId, cycleId, stage])
  @@index([cycleId])
  @@index([userId])
  @@index([evaluatorId])
  @@map("competency_responses")
  @@schema("competency")
}

// M3-4. CompetencyOpinion (역량 평가 종합의견) — 엑셀 역량평가서 [종합의견] 블록.
// 평가자 단계(round1/round2/round3)별 자유 서술 1건. 본인(self) 종합의견은 없음(양식 동일).
model CompetencyOpinion {
  id          String   @id @default(uuid())
  cycleId     String   @map("cycle_id")
  userId      String   @map("user_id") // 피평가자
  stage       String // round1/round2/round3
  evaluatorId String   @map("evaluator_id")
  comment     String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cycle     EvaluationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  user      User            @relation("CompetencyOpinionUser", fields: [userId], references: [id])
  evaluator User            @relation("CompetencyOpinionEvaluator", fields: [evaluatorId], references: [id])

  @@unique([cycleId, userId, stage])
  @@index([userId])
  @@map("competency_opinions")
  @@schema("competency")
}

// ─────────────────────────── M3 (Items 1-3) ───────────────────────────

// M3-Item3. KpiCategoryPolicy — 직책(position)×KPI 카테고리(category) 허용 매트릭스.
// position 당 1행. allowed=허용 카테고리 배열(KpiCategory[]). KPI 작성/제출 시 enforcement.
// 기본 시드: 직책자=전 카테고리, 비직책자(principal·chief·senior·pro)=revenue·orders 차단.
model KpiCategoryPolicy {
  id        String   @id @default(uuid())
  position  String   @unique // 직급 코드(PositionDef.code). enum 폐기 후 String.
  allowed   Json     @default("[]") // KpiCategory[] (camelCase 그대로 enum 문자열 배열)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("kpi_category_policies")
  @@schema("cycle")
}

// 직급 레지스트리 (계약 B-2) — enum Position 폐기 후 관리형. 코드(string)가 User.position 에 저장됨.
// 모델명을 Position 이 아니라 PositionDef 로 한 이유: @prisma/client 의 Position 타입 충돌 방지.
model PositionDef {
  id              String          @id @default(uuid())
  code            String          @unique // 'ceo' … 'pro', 'custom_xxx'
  label           String // '대표이사', 'CTO'
  sortOrder       Int             @map("sort_order") // 낮을수록 상위 직급
  isManagement    Boolean         @default(false) @map("is_management") // 직책자(경영진/본부장/팀장) — KPI 카테고리·통계 기준
  defaultRole     Role            @default(employee) @map("default_role")
  defaultScope    VisibilityScope @default(self) @map("default_scope")
  defaultJobLevel JobLevel?       @map("default_job_level")
  isSystem        Boolean         @default(false) @map("is_system") // 기본 10개=true(삭제/코드변경 차단)
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@map("position_defs")
  @@schema("org")
}

// ─────────────────────────── 권한 설정 (싱글톤) ───────────────────────────
// PermissionConfig — 권한 매트릭스 + 사이드바 nav 가시성을 서버 영속(DB)으로 보관.
// 단일 row(id="singleton"). 프론트 lib/permConfig.ts 와 1:1 (PermLevel × FeatureKey/navKey).
//   matrix:        Record<PermLevel, Record<FeatureKey, boolean>>  (5레벨 × 6기능)
//   navVisibility: Record<PermLevel, Record<navKey,     boolean>>  (5레벨 × NAV_ITEMS key)
// FeatureGuard 가 이 matrix 를 읽어 @RequireFeature 엔드포인트를 추가 차단(restrict-only).
// row/키 누락 시 백엔드 DEFAULT_MATRIX 폴백(fail-to-default, 크래시 금지).
model PermissionConfig {
  id            String   @id @default("singleton")
  matrix        Json     @default("{}") // Record<PermLevel, Record<FeatureKey, boolean>>
  navVisibility Json     @default("{}") @map("nav_visibility") // Record<PermLevel, Record<navKey, boolean>>
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedById   String?  @map("updated_by_id")

  @@map("permission_config")
  @@schema("org")
}

// ─────────────────────────── 6월 중간평가 (Midterm) ───────────────────────────

// MidtermReview — 6월 중간 진척 점검 (per cycle × evaluatee).
// 본인 자가점검(selfNote) + 부서장 확인(reviewerNote). 등급/보상 미반영(비구속 체크포인트).
// status: pending → self_done(본인 제출) → confirmed(부서장 확인).
model MidtermReview {
  id              String              @id @default(uuid())
  cycleId         String              @map("cycle_id")
  evaluateeId     String              @map("evaluatee_id")
  status          MidtermReviewStatus @default(pending)
  // 본인 자가점검
  selfNote        String?             @map("self_note")
  selfSubmittedAt DateTime?           @map("self_submitted_at")
  // 부서장 확인
  reviewerId      String?             @map("reviewer_id")
  reviewerNote    String?             @map("reviewer_note")
  confirmedAt     DateTime?           @map("confirmed_at")
  // 순차 결재(2026-07-07, KPI 결재선과 동일 체인): 완료된 확인 단계 수.
  // self_done+n=중간 확인(다음 단계 대기), confirmed=전 단계 완료.
  reviewStage     Int                 @default(0) @map("review_stage")
  // 확인 이력 [{stage, approverId, approverName, at}]. 반송/재제출 시 리셋.
  reviewTrail     Json?               @map("review_trail")
  // ── 신규 2단계 흐름(2026-07-23) ──
  firstReviewerId   String?   @map("first_reviewer_id") // 1차 평가자(생성 시 스냅샷)
  firstComment      String?   @map("first_comment") @db.Text
  firstCommentedAt  DateTime? @map("first_commented_at")
  memberNote        String?   @map("member_note") @db.Text // 본인 회신 사유
  memberSubmittedAt DateTime? @map("member_submitted_at")
  finalReviewerId   String?   @map("final_reviewer_id") // 2차 검토자(생성 시 스냅샷)
  finalComment      String?   @map("final_comment") @db.Text
  decidedAt         DateTime? @map("decided_at")
  revisionRound     Int       @default(0) @map("revision_round")
  // 본인이 아직 제출하지 않은 수정안 임시저장본(피평가자 개인 작업본).
  // shape = 제출 페이로드와 동일 + 저장 시각:
  //   { items: [{ kpiId, targetValue?, targetText?, weight? }], memberNote: string, savedAt: ISO }
  // 제출본이 아니므로 KPI 행·상태에는 전혀 반영되지 않는다. 제출되면 null 로 비운다
  // (남겨 두면 다음에 화면을 열 때 이미 제출된 값 위로 옛 초안이 되살아난다).
  revisionDraft     Json?     @map("revision_draft")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  cycle     EvaluationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  evaluatee User            @relation("MidtermReviewEvaluatee", fields: [evaluateeId], references: [id])
  reviewer  User?           @relation("MidtermReviewReviewer", fields: [reviewerId], references: [id])
  firstReviewer User?          @relation("MidtermFirstReviewer", fields: [firstReviewerId], references: [id])
  finalReviewer User?          @relation("MidtermFinalReviewer", fields: [finalReviewerId], references: [id])
  trail         MidtermTrail[]

  kpiCheckIns MidtermKpiCheckIn[]

  @@unique([cycleId, evaluateeId])
  @@index([cycleId])
  @@index([evaluateeId])
  @@map("midterm_reviews")
  @@schema("midterm")
}

// MidtermKpiCheckIn — KPI(지표)별 중간 자가점검 (MidtermReview 1:N).
// 사이클 전체 selfNote 와 별개로, 각 KPI 단위 상반기 실적/진척·코멘트·자가 등급을 정규화 저장.
// 비구속(등급/보상 미반영) — selfGrade/reviewerGrade 는 참고용. (midtermReviewId, kpiId) 유일.
model MidtermKpiCheckIn {
  id              String    @id @default(uuid())
  midtermReviewId String    @map("midterm_review_id")
  kpiId           String    @map("kpi_id")
  // 본인 자가점검
  selfActualText  String?   @map("self_actual_text") @db.Text // 상반기 실적/진척 자유서술(정성·정량)
  selfActualValue Float?    @map("self_actual_value") // 선택 수치 진척값
  selfNote        String?   @map("self_note") // KPI별 자가점검 코멘트
  selfGrade       Grade?    @map("self_grade") // 선택 자가 등급(참고용)
  // 부서장 KPI별 코멘트·판정(참고용 — 등급/보상 미반영)
  reviewerNote     String?   @map("reviewer_note")
  reviewerGrade    Grade?    @map("reviewer_grade")
  // KPI별 검토 판정: 'accepted'(수락) | 'rebaseline'(재조정 필요). confirm/sendBack 시 저장.
  reviewerDecision String?   @map("reviewer_decision")
  confirmedAt     DateTime? @map("confirmed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  midtermReview MidtermReview @relation(fields: [midtermReviewId], references: [id], onDelete: Cascade)
  kpi           Kpi           @relation(fields: [kpiId], references: [id])

  @@unique([midtermReviewId, kpiId])
  @@index([midtermReviewId])
  @@index([kpiId])
  @@map("midterm_kpi_check_ins")
  @@schema("midterm")
}

// MidtermTrail — 중간점검 진행 이력(2026-07-23).
// 단계 타임라인 + KPI 필드 전/후 값. 행위자 이름·직책은 인사이동 후에도 보존되도록 스냅샷 저장.
model MidtermTrail {
  id              String   @id @default(uuid())
  midtermReviewId String   @map("midterm_review_id")
  seq             Int // 리뷰 내 순번(1부터)
  action          String // commented | revised | returned | approved | reopened | reassigned
  actorId         String   @map("actor_id")
  actorName       String   @map("actor_name") // 당시 이름 스냅샷
  actorPosition   String?  @map("actor_position") // 당시 직책 스냅샷
  onBehalfOf      Boolean  @default(false) @map("on_behalf_of") // HR 대리 수행
  comment         String?  @db.Text
  kpiChanges      Json?    @map("kpi_changes") // [{ kpiId, kpiTitle, field, before, after }]
  snapshotId      String?  @map("snapshot_id") // 수정 직전 KpiSnapshot id
  createdAt       DateTime @default(now()) @map("created_at")

  midtermReview MidtermReview @relation(fields: [midtermReviewId], references: [id], onDelete: Cascade)
  actor         User          @relation(fields: [actorId], references: [id])

  @@unique([midtermReviewId, seq])
  @@index([midtermReviewId])
  @@index([actorId])
  @@map("midterm_trails")
  @@schema("midterm")
}

// ActionItem — ③ 피드백 보완 조치 추적.
// 부서장이 중간평가 피드백에서 보완 조치(담당·마감)를 등록 → 구성원이 하반기 진행하며 상태 갱신.
// **최종등급 미반영(참고용)** — 12월 최종평가 화면에 "중간 보완 조치 이행 현황" 패널로만 노출.
// 상태전이(planned→in_progress→done, +canceled)는 common/state/transitions.ts(assertTransition) 강제.
model ActionItem {
  id             String           @id @default(uuid())
  cycleId        String           @map("cycle_id")
  evaluateeId    String           @map("evaluatee_id") // 대상 구성원
  kpiId          String?          @map("kpi_id") // 선택 연결 KPI
  source         ActionItemSource @default(midterm_review)
  title          String
  detail         String?
  assigneeId     String           @map("assignee_id") // 담당(보통 본인)
  dueDate        DateTime?        @map("due_date")
  status         ActionItemStatus @default(planned)
  createdById    String           @map("created_by_id")
  completedAt    DateTime?        @map("completed_at")
  completionNote String?          @map("completion_note")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  cycle     EvaluationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  evaluatee User            @relation("ActionItemEvaluatee", fields: [evaluateeId], references: [id])
  assignee  User            @relation("ActionItemAssignee", fields: [assigneeId], references: [id])
  createdBy User            @relation("ActionItemCreatedBy", fields: [createdById], references: [id])
  kpi       Kpi?            @relation(fields: [kpiId], references: [id])

  @@index([cycleId])
  @@index([evaluateeId])
  @@index([cycleId, evaluateeId])
  @@index([assigneeId])
  @@index([kpiId])
  @@map("action_items")
  @@schema("midterm")
}

// RebaselineRequest — ④ 중간 KPI 목표 재조정 요청(본인 제안 → 부서장 검토 → 승인 시 반영).
// 제안 주체 = 피평가자 본인(evaluateeId). 검토·승인자 = 그 구성원의 부서장(reviewerId, 승인 시 기록).
// items(Json) = [{ kpiId, targetValue?, targetText?, weight? }] 제안 변경 필드.
// 실제 KPI 변경·KpiSnapshot·AuditLog 는 **승인(approved) 시점**에만 발생(appliedSnapshotId 기록).
// 상태: submitted → approved(종단) | rejected → submitted(재제출). transitions.ts 강제.
// "한 cycle×evaluatee 당 미결(submitted) 요청 1건"은 부분 unique 가 Postgres 표준 @@unique 로
// 불가하므로(상태 조건부) 서비스에서 검증한다.
model RebaselineRequest {
  id                String                  @id @default(uuid())
  cycleId           String                  @map("cycle_id")
  evaluateeId       String                  @map("evaluatee_id") // 요청자 = 피평가자 본인
  reason            String // 재조정 사유(필수)
  items             Json // [{ kpiId, targetValue?, targetText?, weight? }]
  status            RebaselineRequestStatus @default(submitted)
  reviewerId        String?                 @map("reviewer_id") // 검토(승인/반려)한 부서장
  reviewComment     String?                 @map("review_comment")
  reviewedAt        DateTime?               @map("reviewed_at")
  appliedSnapshotId String?                 @map("applied_snapshot_id") // 승인 시 캡처한 직전 KpiSnapshot id
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  cycle     EvaluationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  evaluatee User            @relation("RebaselineRequestEvaluatee", fields: [evaluateeId], references: [id])
  reviewer  User?           @relation("RebaselineRequestReviewer", fields: [reviewerId], references: [id])

  @@index([cycleId])
  @@index([evaluateeId])
  @@index([cycleId, evaluateeId])
  @@index([reviewerId])
  @@index([status])
  @@map("rebaseline_requests")
  @@schema("midterm")
}
